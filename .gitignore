# macOS system files
.DS_Store

# Virtual environments
.venv/
venv/
ENV/
env/
*.env

# Python bytecode and build artifacts
__pycache__/
*.py[cod]
*.so
*.egg-info/
build/
dist/

# IDE & editor settings
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/
profile_default/
ipython_config.py

# Output and data — root-only patterns so they catch dev-scratch
# directories at the repo root (output/, data/, temp/, results/, etc.)
# without silently ignoring nested benchmark data such as
# lm_eval/tasks/realguardrails/s_rules/data/, lm_eval/tasks/bfcl_v3/data/,
# or lm_eval/tasks/mt_bench/data/, which are vendored and must be tracked.
# (Git cannot re-include children of an ignored directory, so the parent
# patterns themselves must be anchored.)
/output/
/data/
/temp/
/test_logs/
/results/

# Caching
lm_eval/caching/.cache
lm_cache/

# Logging
*.log
logs/

# wandb experiment tracking
wandb/
examples/wandb/

# PyInstaller
*.spec
out/*

#uv
uv.lock
